# LAN gateway - HTTP only for now
# Access: http://10.25.115.100

:80 {
	encode gzip zstd

	# WebSocket connections
	handle /ws/* {
		reverse_proxy backend:8000
	}

	# API proxy routes
	handle /api/proxy/* {
		reverse_proxy frontend:3000
	}

	# API routes
	handle_path /api/* {
		reverse_proxy backend:8000
	}

	# Frontend
	handle {
		reverse_proxy frontend:3000
	}
}
