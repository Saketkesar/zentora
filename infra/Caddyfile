# Serve the app securely at https://zentora.local
# This uses Caddy's local HTTPS (self-signed cert trusted locally if you install the root CA)

zentora.local {
	encode gzip zstd
	# Frontend on port 3000
	reverse_proxy  frontend:3000
}

